{
  "name": "atari-portal",
  "version": "1.0.0",
  "description": "Atari Portal — retro game collection connected through portals",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "make-icon": "node scripts/make-icon.cjs",
    "pack-win": "npm run build && electron-builder --win zip --publish never",
    "pack-mac": "npm run build && electron-builder --mac zip --x64 --arm64 --publish never"
  },
  "build": {
    "appId": "com.atariportal.game",
    "productName": "Atari Portal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "public/assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "icon": "public/assets/icon.icns",
      "identity": "-",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    }
  },
  "dependencies": {
    "phaser": "^3.86.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^6.2.0"
  }
}
